{
  "name": "claudepad",
  "version": "0.2.0",
  "type": "module",
  "description": "Claude Code Session Monitor - Web-based terminal for Claude Code",
  "author": "yangjing",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yangjingo/ClaudePad.git"
  },
  "bugs": {
    "url": "https://github.com/yangjingo/ClaudePad/issues"
  },
  "homepage": "https://github.com/yangjingo/ClaudePad#readme",
  "keywords": [
    "claude",
    "claude-code",
    "terminal",
    "monitor",
    "ssh"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch backend/index.ts",
    "start": "node dist/index.js",
    "clean": "node -e \"require('fs').rmSync('dist',{ recursive: true, force: true })\"",
    "package:win": "node scripts/package-win.mjs",
    "package:linux": "node scripts/package-linux.mjs"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "ssh2": "^1.17.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.18.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "pkg": "^5.8.1",
    "playwright": "^1.58.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "frontend/",
    "asserts/"
  ],
  "bin": {
    "claudepad": "dist/index.js"
  },
  "pkg": {
    "assets": [
      "frontend/**/*",
      "asserts/**/*",
      "docs/**/*",
      "node_modules/node-pty/build/Release/**",
      "node_modules/node-pty/build/Debug/**"
    ]
  }
}
